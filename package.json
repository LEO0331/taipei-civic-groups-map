{
  "name": "taipei-civic-groups-map",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "tsx --test src/lib/*.test.ts",
    "data:fetch:civic-groups": "tsx scripts/fetchCivicGroups.ts",
    "data:fetch:industry-grants": "tsx scripts/fetchIndustryGrantRecipients.ts",
    "data:fetch:metro-procurement": "tsx scripts/fetchMetroProcurementSchedules.ts",
    "data:fetch:registered-cram-schools": "tsx scripts/fetchRegisteredCramSchools.ts",
    "data:fetch:registered-hotels": "tsx scripts/fetchRegisteredHotels.ts",
    "data:fetch:labor-violations": "tsx scripts/fetchLaborStandardActViolationRecords.ts",
    "data:fetch:nangang-software-park": "tsx scripts/fetchNangangSoftwareParkCompanies.ts",
    "data:fetch": "npm run data:fetch:civic-groups && npm run data:fetch:industry-grants && npm run data:fetch:metro-procurement && npm run data:fetch:registered-cram-schools && npm run data:fetch:registered-hotels && npm run data:fetch:labor-violations && npm run data:fetch:nangang-software-park",
    "data:convert:civic-groups": "tsx scripts/convertCivicGroups.ts && tsx scripts/buildCivicGroupSummary.ts",
    "data:convert:industry-grants": "tsx scripts/convertIndustryGrantRecipients.ts && tsx scripts/buildIndustryGrantSummary.ts",
    "data:convert:metro-procurement": "tsx scripts/convertMetroProcurementSchedules.ts && tsx scripts/buildMetroProcurementSummary.ts",
    "data:convert:registered-cram-schools": "tsx scripts/convertRegisteredCramSchools.ts && tsx scripts/buildRegisteredCramSchoolSummary.ts",
    "data:convert:registered-hotels": "tsx scripts/convertRegisteredHotels.ts",
    "data:convert:labor-violations": "tsx scripts/convertLaborStandardActViolationRecords.ts && tsx scripts/buildLaborStandardActViolationSummary.ts",
    "data:convert:nangang-software-park": "tsx scripts/convertNangangSoftwareParkCompanies.ts && tsx scripts/buildNangangSoftwareParkCompanySummary.ts",
    "data:convert": "npm run data:convert:civic-groups && npm run data:convert:industry-grants && npm run data:convert:metro-procurement && npm run data:convert:registered-cram-schools && npm run data:convert:registered-hotels && npm run data:convert:labor-violations && npm run data:convert:nangang-software-park && tsx scripts/buildPublicRecordsSummary.ts"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.18",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "tsx": "^4.20.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
