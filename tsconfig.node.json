{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "strict": true,
    "noEmit": true
  },
  "include": ["vite.config.ts", "scripts/**/*.ts", "src/lib/**/*.ts"]
}
